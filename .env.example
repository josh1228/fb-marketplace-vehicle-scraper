# Copy this file to .env and fill in the values.
# cp .env.example .env

# ── Scraper settings ─────────────────────────────────────────────────────────
# Maximum number of requests per minute (default: 10)
SCRAPER_RATE_LIMIT=10

# HTTP request timeout in seconds (default: 30)
SCRAPER_TIMEOUT=30

# Number of retry attempts on failure (default: 3)
SCRAPER_RETRIES=3

# ── API settings ─────────────────────────────────────────────────────────────
# Host the API listens on (default: localhost)
API_HOST=localhost

# Port the API listens on (default: 8080)
API_PORT=8080

# ── Database (optional) ───────────────────────────────────────────────────────
# SQLAlchemy-style database URL (default: in-memory SQLite)
DATABASE_URL=sqlite:///./listings.db

# ── HTTP client ───────────────────────────────────────────────────────────────
# User-Agent header sent with each scraping request
USER_AGENT=fb-marketplace-scraper
